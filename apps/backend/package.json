{
  "name": "@concierge/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @concierge/shared build && tsx watch src/index.ts",
    "start": "node dist/index.js",
    "mock:approval": "node scripts/seed-mock-approval.mjs",
    "build": "pnpm --filter @concierge/shared build && tsc -p tsconfig.build.json",
    "lint": "pnpm --filter @concierge/shared build && tsc -p tsconfig.json --noEmit",
    "typecheck": "pnpm --filter @concierge/shared build && tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@concierge/shared": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "fastify": "^5.2.1",
    "nanoid": "^5.0.9",
    "pino": "^9.6.0",
    "sql.js": "^1.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.9",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
